# TCRB Agent — Environment Configuration
# Copy to .env and fill in values

# Anthropic API key for content generation
ANTHROPIC_API_KEY=

# GitHub Personal Access Token (for pushing site updates)
GITHUB_TOKEN=

# Instagram (optional — for future direct posting)
# IG_ACCESS_TOKEN=

# Agent Settings
DATA_UPDATE_INTERVAL_HOURS=4
SITE_REPO_PATH=/Users/supertramp/tcrb-site
INSTAGRAM_OUTPUT_PATH=/Users/supertramp/tcrb-site/instagram
